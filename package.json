{
  "name": "wavemaker-cli-sanity",
  "version": "1.0.0",
  "description": "WaveMaker React Native CLI Sanity Testing Framework (POM Architecture)",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "clean": "rimraf dist",
    "prebuild": "npm run clean",
    "test": "npx mocha --reporter allure-mocha --require ts-node/register --timeout 999999 'test/specs/**/*.spec.ts'",
    "test:appchef": "npx mocha --reporter allure-mocha --require ts-node/register --timeout 30000 test/specs/appchef-version.spec.ts",
    "test:preview": "npx mocha --reporter allure-mocha --require ts-node/register --timeout 999999 test/specs/preview-cli.spec.ts",
    "test:build": "npx mocha --reporter allure-mocha --require ts-node/register --timeout 999999 test/specs/app-build.spec.ts",
    "test:maven": "npx mocha --reporter allure-mocha --require ts-node/register --timeout 999999 test/specs/maven-expo.spec.ts",
    "report:generate": "allure generate allure-results --clean --single-file -o allure-report",
    "report:open": "allure open allure-report",
    "report:upload": "npx ts-node scripts/generate-and-upload-report.ts"
  },
  "keywords": [
    "wavemaker",
    "react-native-cli",
    "cli",
    "testing",
    "automation"
    
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.997.0",
    "@wavemaker/wm-reactnative-cli": "latest",
    "@wavemaker-ai/wm-reactnative-cli": "latest",
    "adm-zip": "^0.5.16",
    "axios": "^1.7.7",
    "chalk": "^4.1.2",
    "commander": "^11.0.0",
    "dotenv": "^16.0.3",
    "ora": "^5.4.1",
    "qs": "^6.11.2",
    "otpauth": "^9.3.6",
    "semver": "^7.7.4"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.19.1",
    "@types/qs": "^6.14.0",
    "@types/semver": "^7.7.1",
    "allure-mocha": "^3.5.0",
    "mocha": "^10.8.2",
    "rimraf": "^5.0.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3",
    "webdriverio": "^8.31.1"
  }
}
