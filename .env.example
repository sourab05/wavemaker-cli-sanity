# Package Manager: "npm", "yarn", or "both"
PACKAGE_MANAGER=npm

# WaveMaker Studio Credentials
WM_USERNAME=your_email@wavemaker.com
WM_PASSWORD=your_password

# WaveMaker Project Configuration
WM_PROJECT_ID=WMPRJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WM_ENVIRONMENT=stage
DEPLOYED_SERVER_URL=https://your-deployed-app.com/services
MOBILE_SERVER_URL=https://stage-studio.wavemakeronline.com/run-xxxxx/services

# Android Configuration
ANDROID_DEVICE_NAME=emulator-5554
ANDROID_EMULATOR_NAME=Pixel8
LOCAL_DEVICE_NAME=emulator-5554
LOCAL_PLATFORM_VERSION=14
PLATFORM_NAME=android

# iOS Configuration (for iOS builds)
IOS_P12_CERT_PATH=/path/to/Certificates.p12
IOS_PROVISION_PROFILE_PATH=/path/to/profile.mobileprovision
IOS_P12_PASSWORD=your_password
IOS_SIMULATOR_DEVICE=iPhone 15
IOS_SIMULATOR_RUNTIME=

# BrowserStack Configuration (optional)
RUN_LOCAL=true
BROWSERSTACK_USERNAME=your_browserstack_username
BROWSERSTACK_ACCESS_KEY=your_browserstack_key
PROJECT_NAME=CliSanity
BS_ANDROID_DEVICE_NAME=Google Pixel 8
BS_ANDROID_PLATFORM_VERSION=14
IOS_DEVICE_NAME=iPhone 15 Plus
IOS_PLATFORM_VERSION=17

# Headless Chrome (set to true for CI/headless Linux)
HEADLESS=false

# App Configuration
APP_NAME=CliSanity
APP_PACKAGE=com.wavemaker.clisanity
APP_ACTIVITY=.MainActivity
APP_VERIFICATION_ID=~mobile_navbar1_title

# Studio Configuration
LOGIN_URL=https://stage-studio.wavemakeronline.com/login/authenticate
STUDIO_URL=https://stage-studio.wavemakeronline.com

# S3 Report Upload (optional)
S3_REPORT_BUCKET=
S3_REPORT_VERSION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-west-2